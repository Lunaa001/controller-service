# NotebookUm Controller - Environment Configuration

# Server
PORT=5000
X_CORRELATION_HEADER=X-Correlation-ID
X_USER_ID_HEADER=X-User-ID
REQUEST_TIMEOUT=30

# Redis Cache
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=notebookum_redis_pass

# Microservices URLs
USER_SERVICE_URL=http://localhost:8001
EXTRACT_SERVICE_URL=http://localhost:8002
SUMMARY_SERVICE_URL=http://localhost:8003
PERSISTENCE_URL=http://localhost:8004

# Docker Compose Overrides
# USER_SERVICE_URL=http://user-service:8001
# EXTRACT_SERVICE_URL=http://extract-service:8002
# SUMMARY_SERVICE_URL=http://summary-service:8003
# PERSISTENCE_URL=http://persistence-service:8004
